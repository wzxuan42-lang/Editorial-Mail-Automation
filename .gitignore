# ── 敏感凭证（绝不上传）─────────────────────────────────────────────────────
credentials.json
token.json
.env

# ── 运行时生成的数据文件 ──────────────────────────────────────────────────────
sent_log.json
*.log
logs/*
!logs/.gitkeep

# ── 下载内容（可能含版权作品）────────────────────────────────────────────────
downloads/*
!downloads/.gitkeep

# ── 评审数据（含个人信息）────────────────────────────────────────────────────
reviews.xlsx
*.xlsx
*.xls

# ── Python 缓存 ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 构建产物 ──────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.spec

# ── macOS 系统文件 ────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── IDE 配置 ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── 占位文件（保留目录结构）──────────────────────────────────────────────────
!contracts/.gitkeep
!docs/.gitkeep
