# ── Gemini AI ─────────────────────────────────────────────────────────────────
# 从 https://aistudio.google.com/app/apikey 获取
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail API 凭证路径 ─────────────────────────────────────────────────────────
# 从 Google Cloud Console 下载并放置于项目根目录
CREDENTIALS_FILE=credentials.json
TOKEN_FILE=token.json

# ── Reviewer 配置 ──────────────────────────────────────────────────────────────
# Excel 评审表路径
EXCEL_FILE=reviews.xlsx

# 合同文件夹路径
CONTRACTS_DIR=contracts

# 已发送记录文件（自动生成，防止重复发送）
SENT_LOG_FILE=sent_log.json

# 邮件发件人显示名称
SENDER_NAME=龙与十字星编辑部

# 邮件主题前缀
EMAIL_SUBJECT_PREFIX=【龙与十字星】投稿评审结果通知

# 合同文件名
CONTRACT_FILENAME=《龙与十字星》出版合同.docx
